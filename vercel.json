{
  "version": 2,
  "routes": [
    {
      "src": "^/$",
      "dest": "/public/index.html",
      "headers": { "Cache-Control": "no-store" }
    },
    {
      "src": "^/(?!api/).*",
      "dest": "/api/proxy",
      "headers": { "Cache-Control": "no-store" }
    }
  ],
  "functions": {
    "api/proxy.js": {
      "maxDuration": 30
    }
  },
  "headers": [
    {
      "source": "/api/(.*)",
      "headers": [
        { "key": "Access-Control-Allow-Origin", "value": "*" },
        { "key": "Access-Control-Allow-Methods", "value": "GET, POST, PUT, DELETE, OPTIONS, PATCH" },
        { "key": "Access-Control-Allow-Headers", "value": "*" }
      ]
    }
  ]
}
